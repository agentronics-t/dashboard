{
  "name": "@agentronics/intel-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/client.d.ts",
      "default": "./dist/db/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "db:generate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "node --env-file=.env dist/db/seed.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0"
  }
}
