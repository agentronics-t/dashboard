# dashboard — Next.js on Vercel
# Neon (serving mirror) — same DB the pipeline writes
DATABASE_URL=

# intel-api base URL (for "Run import now")
INTEL_API_URL=https://intel-api-1032662679519.asia-south1.run.app

# Clerk (optional in dev — without it the app uses the demo tenant)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Override to point sign-in/up at the landing page once it hosts auth.
# Leave unset to use the dashboard-hosted /sign-in and /sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=

# Vertex AI for agent chat (optional in dev — falls back to retrieval-only answers)
GCP_PROJECT=project-6d96c09a-5821-4133-959
VERTEX_LOCATION=asia-south1
GEMINI_MODEL=gemini-2.5-flash
EMBED_MODEL=text-embedding-005
# Service-account JSON (string) for Vertex on Vercel; locally uses ADC if unset
GOOGLE_GENAI_SA_KEY=
